# Supabase 项目配置 — 复制为 .env.local 后填入实际值
# 本地开发：npx supabase start 后从终端输出取值
# 云端环境：Supabase Dashboard → Project Settings → API

# Supabase 项目 URL（本地默认 http://127.0.0.1:54321）
NEXT_PUBLIC_SUPABASE_URL=

# anon 公钥（浏览器端使用，受 RLS 保护）
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service_role 密钥（仅服务端，绕过 RLS —— 绝不可泄漏到客户端/提交到 git）
SUPABASE_SERVICE_ROLE_KEY=

# 可选：服务端专用 URL（未设置时回退到 NEXT_PUBLIC_SUPABASE_URL）
# SUPABASE_URL=
